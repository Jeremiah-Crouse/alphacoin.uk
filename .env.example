# Server Configuration
PORT=3000
NODE_ENV=development

# Admin Model Configuration
# Options: opencode, openai, local
ADMIN_MODEL=opencode

# OpenCode Zen Protocol (Big Pickle)
ADMIN_API_KEY=your_opencode_api_key_here
ADMIN_MODEL_NAME=big-pickle
OPENCODE_ZEN_URL=https://api.opencode.com/zen

# Brevo (Transactional Email)
BREVO_API_KEY=your_brevo_api_key_here

# Gmail Integration
# Requires OAuth2 credentials.json file in root
# Get credentials from: https://console.cloud.google.com/
GMAIL_ENABLED=false

# Email Addresses
ADMIN_EMAIL=admin@alphacoin.uk
CONTACT_EMAIL=eljpeg328@gmail.com
